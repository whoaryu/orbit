# Orbit - Environment Configuration Example

# ==========================================
# BACKEND SETTINGS (under ./backend/.env)
# ==========================================

# Connection string for your MongoDB database (optional but recommended for matchmaking history/features)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/orbitDB?retryWrites=true&w=majority

# Port for the express and websocket signaling server to run on
PORT=3001

# Application environment (development or production)
NODE_ENV=development


# ==========================================
# FRONTEND SETTINGS (under ./frontend/.env)
# ==========================================

# WebSocket Server URL for signalling (use ws://localhost:3001 in development)
VITE_WS_URL=ws://localhost:3001
